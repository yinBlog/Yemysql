{
  "name": "mysql-client",
  "version": "1.0.0",
  "description": "一个基于 Electron 的 MySQL 连接管理与查询工具",
  "main": "src/main/main.js",
  "author": "yinhuan",
  "license": "MIT",
  "scripts": {
    "start": "node node_modules/electron/cli.js .",
    "dev": "node node_modules/electron/cli.js . --dev",
    "smoke": "node node_modules/electron/cli.js scripts/smoke.js",
    "icon": "node scripts/gen-icon.js",
    "pack": "node node_modules/electron-builder/cli.js --dir",
    "dist": "node node_modules/electron-builder/cli.js --win"
  },
  "dependencies": {
    "mysql2": "^3.11.5",
    "pg": "^8.13.1",
    "sql.js": "^1.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "32.3.3",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "com.qsy.mysqlclient",
    "productName": "MySQL Client",
    "electronDist": "node_modules/electron/dist",
    "electronVersion": "32.3.3",
    "asarUnpack": ["**/node_modules/sql.js/dist/sql-wasm.wasm"],
    "directories": { "output": "release" },
    "files": [
      "src/**/*",
      "package.json",
      "!**/*.map"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "MySQLClient-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "MySQL客户端",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
